# Configuración del backend (C17). Copia a `.env` y ajusta. Prefijo: ARB_
# Defaults completos en app/config.py (Apéndice E de la arquitectura).

ARB_ENV=dev
ARB_LOG_LEVEL=INFO
# JSON para listas:
ARB_CORS_ORIGINS=["http://localhost:3000"]

# Override anidado por exchange (delimitador `__`):
# ARB_EXCHANGES__BINANCE__FEE_TAKER=0.0009
# ARB_EXCHANGES__COINBASE__ENABLED=true

# Umbrales:
# ARB_STALENESS_MS=750
# ARB_MAX_SLIPPAGE=0.0010
# ARB_MIN_NET_PROFIT_USD=0.0

# Persistencia:
# ARB_DB_URL=sqlite+aiosqlite:///./arbitraje.db
