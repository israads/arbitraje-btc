# Frontend Next.js para despliegue standalone tras nginx (mismo origen).
# NEXT_PUBLIC_API_BASE="" ⇒ el cliente usa rutas relativas (/api, /health).
FROM node:20-slim

WORKDIR /app

COPY frontend/package*.json ./
RUN npm ci

COPY frontend/ ./

ENV NEXT_PUBLIC_API_BASE=""
ENV NEXT_TELEMETRY_DISABLED=1
RUN npm run build

# Usuario no privilegiado (imagen node trae `node`): `next start` escribe cache en .next.
RUN chown -R node:node /app/.next
USER node

EXPOSE 3000
CMD ["npm", "run", "start"]
