# Copia este archivo a `.env` en este mismo directorio y edita los valores.
# El `.env` real NUNCA se versiona (está en .gitignore); se crea en el servidor.

# OBLIGATORIO: token del plano de control (kill-switch, resume, demo, config, retención).
# El compose falla explícitamente si falta y el backend se niega a arrancar sin él en prod.
# Generar uno fuerte: openssl rand -hex 24
ARB_CONTROL_TOKEN=

# OPCIONAL: ventana de datos retenida en horas (poda de fondo del backend).
# Dimensiona el disco según la tasa real del host (venues activos y volatilidad);
# medida de referencia con 4 venues USD: ~17 MB/h → 600 h ≈ 10 GB.
# ARB_DB_RETENTION_HOURS=600

# --- Tuning para hosts pequeños (≤2 cores). El compose inyecta este .env completo
# --- al backend (env_file), así que cualquier ARB_* puede ajustarse aquí.
# Menos venues = menos CPU del engine. OJO: ARB_EXCHANGES sustituye el dict ENTERO
# (el override parcial ARB_EXCHANGES__X__CAMPO no fusiona con defaults y no arranca).
# ARB_EXCHANGES={"kraken":{"id":"kraken","symbol":"BTC/USD","quote_ccy":"USD","fee_taker":0.0040,"withdrawal_btc":0.00005,"ob_limit":25},"coinbase":{"id":"coinbase","symbol":"BTC/USD","quote_ccy":"USD","fee_taker":0.0060,"withdrawal_btc":0.0001,"ob_limit":50},"gemini":{"id":"gemini","symbol":"BTC/USD","quote_ccy":"USD","fee_taker":0.0040,"withdrawal_btc":0.0001,"ob_limit":50},"bitstamp":{"id":"bitstamp","symbol":"BTC/USD","quote_ccy":"USD","fee_taker":0.0030,"withdrawal_btc":0.0001,"ob_limit":100}}
# Buffer de grabación para replay/demo (coste del backtest ∝ tamaño).
# ARB_RECORD_MAXLEN=5000
# Muestras shadow para calibración de supervivencia (coste ∝ samples × ticks).
# ARB_SHADOW_SAMPLE_MAXLEN=500
