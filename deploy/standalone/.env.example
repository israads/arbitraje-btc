# Copia este archivo a `.env` en este mismo directorio y edita los valores.
# El `.env` real NUNCA se versiona (está en .gitignore); se crea en el servidor.

# OBLIGATORIO: token del plano de control (kill-switch, resume, demo, config, retención).
# El compose falla explícitamente si falta y el backend se niega a arrancar sin él en prod.
# Generar uno fuerte: openssl rand -hex 24
ARB_CONTROL_TOKEN=

# OPCIONAL: ventana de datos retenida en horas (poda de fondo del backend).
# Dimensiona el disco: horas × ~28 MB. 24 ≈ 0.7 GB (default) · 528 ≈ 15 GB.
# ARB_DB_RETENTION_HOURS=528
